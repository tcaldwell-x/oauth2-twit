# X (Twitter) API OAuth 2.0 credentials.
# Create an app at https://developer.x.com and enable OAuth 2.0.
# Set the "Type of App" to "Web App" (confidential client) or "Native/SPA"
# (public client). For a confidential client, also set X_CLIENT_SECRET.

# Required: OAuth 2.0 Client ID
X_CLIENT_ID=

# Optional: OAuth 2.0 Client Secret (only for confidential "Web App" clients)
X_CLIENT_SECRET=

# Optional: Exact callback URL registered in the X developer portal.
# If omitted, it is derived from the request origin as <origin>/api/auth/callback
# Local dev example:  http://127.0.0.1:3000/api/auth/callback
# Production example:  https://your-app.vercel.app/api/auth/callback
X_REDIRECT_URI=
